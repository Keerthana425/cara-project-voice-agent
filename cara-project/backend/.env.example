# Cara Backend — Environment Variables
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000
ENV=development

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# OpenAI (for Whisper STT and/or GPT-4 LLM responses)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (alternative LLM — Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# TTS provider: "browser" | "elevenlabs" | "google"
TTS_PROVIDER=browser
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Database (leave blank to use in-memory)
DATABASE_URL=

# Redis (for session persistence across instances)
REDIS_URL=

# Logging
LOG_LEVEL=INFO
